# ── Base de datos (Railway PostgreSQL) ───────────────────────────────────────
# Railway la inyecta automáticamente como DATABASE_URL
# Local: postgres://user:password@localhost:5432/facturas
DATABASE_URL=postgresql://postgres:password@localhost:5432/facturas

# ── Redis (Railway Redis plugin) ──────────────────────────────────────────────
# Railway la inyecta automáticamente como REDIS_URL
# Local: redis://localhost:6379
REDIS_URL=redis://localhost:6379

# ── Anthropic ─────────────────────────────────────────────────────────────────
# console.anthropic.com → API Keys
ANTHROPIC_API_KEY=sk-ant-...

# ── API ───────────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development
# URL pública del frontend (para CORS) — en Railway es el dominio del servicio web
CORS_ORIGIN=http://localhost:5173

# ── Web (build time) ──────────────────────────────────────────────────────────
# URL pública del backend — en Railway es el dominio del servicio API
VITE_API_URL=http://localhost:3000
